# 应用配置
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=production

# 端口映射 (默认 5000)
PORT=5000

# 数据持久化路径 (可选)
# 上传文件存储路径
UPLOAD_PATH=./uploads
# 数据库和配置存储路径
DATA_PATH=./instance

# CORS 允许来源 (生产环境建议设置)
# 多个来源用逗号分隔，如: http://1.2.3.4:8080,https://example.com
ALLOWED_ORIGINS=*

# 公网地址配置 (用于生成分享链接)
# PUBLIC_URL=https://your-domain.com
